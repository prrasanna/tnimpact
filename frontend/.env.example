# Backend API URL
# Change this to your backend server URL
VITE_API_URL=http://127.0.0.1:8000

# ==========================================
# Phase 2 Voice Features - Porcupine Wake Word
# ==========================================
# Porcupine provides wake word detection ("Hey Logistics")
# Sign up at: https://console.picovoice.ai/
# Free tier includes: 3 custom wake words, unlimited usage
# Copy your Access Key from the console
VITE_PORCUPINE_ACCESS_KEY=zRDC8UQiIWZl3T6rHCZZ7UNRrG3yDNQf9l+x1JJfyFOELXyUrA62Qg==

# Wake Word Configuration
# Set to true to enable hands-free wake word activation
# Set to false to use button press (current behavior)
VITE_WAKE_WORD_ENABLED=false

# Wake word sensitivity (0.0 - 1.0)
# Lower = fewer false positives, may miss some wake words
# Higher = more sensitive, may have false positives
# Recommended: 0.5 for balanced performance
VITE_WAKE_WORD_SENSITIVITY=0.5
